FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /worker-agent ./cmd/worker-agent

FROM alpine:3.19
RUN apk add --no-cache ca-certificates curl bash
COPY --from=builder /worker-agent /usr/local/bin/worker-agent
ENTRYPOINT ["worker-agent"]
