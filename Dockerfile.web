FROM node:20-alpine AS build
WORKDIR /app
COPY web/package.json ./
RUN npm install
COPY web/ ./
RUN npm run build

FROM node:20-alpine
RUN adduser -D -u 1001 appuser || true
WORKDIR /app
COPY web/server.js ./
COPY --from=build /app/dist ./dist
USER appuser
EXPOSE 3000
ENV PORT=3000
CMD ["node", "server.js"]